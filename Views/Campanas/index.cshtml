@model List<PortalCampanasComerciales.Models.Campana>

@{
    ViewData["Title"] = "Listado de Campañas";
}

<div class="container mt-4">
    <h2 class="mb-4">Listado de Campañas Comerciales</h2>

    <!-- Filtros -->
<div class="row mb-4">
    <div class="col-md-8">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-4">
                <select name="categoria" class="form-select">
                    <option value="">Todas las categorías</option>
                    @if (ViewBag.Categorias != null)
                    {
                        foreach (var cat in (List<string>)ViewBag.Categorias)
                        {
                            <option value="@cat" selected="@(ViewContext.HttpContext.Request.Query["categoria"] == cat ? "selected" : null)">@cat</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4">
                <select name="estado" class="form-select">
                    <option value="">Todos los estados</option>
                    <option value="Vigente" selected="@(ViewContext.HttpContext.Request.Query["estado"] == "Vigente" ? "selected" : null)">Vigente</option>
                    <option value="Próxima" selected="@(ViewContext.HttpContext.Request.Query["estado"] == "Próxima" ? "selected" : null)">Próxima</option>
                    <option value="Finalizada" selected="@(ViewContext.HttpContext.Request.Query["estado"] == "Finalizada" ? "selected" : null)">Finalizada</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
            <div class="col-md-2">
                <a asp-action="Index" class="btn btn-secondary w-100">Limpiar</a>
            </div>
        </form>
    </div>
</div>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Categoría</th>
                <th>Estado</th>
                <th>Canal</th>
                <th>Descuento</th>
                <th>Fechas</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nombre</td>
                    <td>@item.Categoria</td>
                    <td>
                        <span class="badge @(item.Estado == "Vigente" ? "bg-success" : item.Estado == "Próxima" ? "bg-warning" : "bg-secondary")">
                            @item.Estado
                        </span>
                    </td>
                    <td>@item.Canal</td>
                    <td>@item.DescuentoPct %</td>
                    <td>@item.FechaInicio.ToString("dd/MM/yyyy") - @item.FechaFin.ToString("dd/MM/yyyy")</td>
                    <td>
                        <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Ver Detalle</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>